digraph API {
  rankdir=LR;
  node [shape=box, style=rounded];
  "root" -> "api";
  "api" -> "v1";
  "v1" -> "v2";
  "api" -> "graphql";
  "api" -> "health";
  "api" -> "issues";
  "api" -> "orgs";
  "orgs" -> "{org}";
  "{org}" -> "repos";
  "api" -> "rate_limit";
  "api" -> "repos";
  "repos" -> "{owner}";
  "{owner}" -> "{repo}";
  "{repo}" -> "issues";
  "api" -> "search";
  "api" -> "status";
  "api" -> "user";
  "api" -> "users";
  "users" -> "{user}";
}

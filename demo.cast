{"version": 2, "width": 89, "height": 20, "timestamp": 1772657205, "env": {"SHELL": "/bin/bash", "TERM": "xterm-kitty"}}
[0.001174, "o", "\r\n# ------------------------------------------------\r\n# render animated svg\r\n# ------------------------------------------------\r\necho \"Rendering SVG animation...\"\r\n\r\nsvg-term \\\r\n  --in demo.cast \\\r\n  --out demo.svg \\\r\n  --window \\\r\n  --padding 20 \\\r\n  --width 80 \\\r\n  --height 24 \\\r\n  --term iterm2"]
[0.002471, "o", "\r\n\r\n# ------------------------------------------------\r\n# add animation to README\r\n# ------------------------------------------------\r\nif [ -f README.md ]; then\r\n  if ! grep -q \"demo.svg\" README.md; then\r\n    echo \"Updating README...\"\r\n    tmp=$(mktemp)\r\n    echo '<p align=\"center\"><img src=\"demo.svg\"></p>' > \"$tmp\"\r\n    echo >> \"$tmp\"\r\n    cat README.md >> \"$tmp\"\r\n    mv \"$tmp\" README.md\r\n  fi\r\nelse\r\n  echo \"# Restless\" > README.md\r\n  echo '<p align=\"center\"><img src=\"demo.svg\"></p>' >> README.md\r\nfi\r\n\r\necho\r\necho \"✨ Demo ready\"\r\necho\r\necho \"Files created:\"\r\necho \"  demo.svg   (animated terminal)\"\r\necho \"  demo.cast\"\r\necho \"  scripts/demo_recon.sh\"\r\necho\r\necho \"Commit with:\"\r\necho \"  git add demo.svg scripts/demo_recon.sh README.md\"\r\necho \"  git commit -m 'add animated recon demo'\"\r\necho\r\n"]
[0.008252, "o", "\u001b[H\u001b[2J"]
[0.008977, "o", "\u001b[38;5;214m⚙ RESTLESS RECON ENGINE ⚙\u001b[0m\r\n\u001b[38;5;220msteampunk network probe initiating...\u001b[0m\r\n"]
[1.011625, "o", "\r\n\u001b[38;5;45mTarget locked:\u001b[0m https://api.github.com"]
[2.016703, "o", "\r\n$ restless auto https://api.github.com\r\n"]
[3.025348, "o", "⚡ restless autonomous mode\r\ntarget: https://api.github.com\r\ngenerated targets:\r\n - https://api.github.com/api\r\n - https://api.github.com/v1\r\n - https://api.github.com/v2\r\n - https://api.github.com/graphql\r\ntip: add --repo owner/repo to dispatch swarm\r\n"]
